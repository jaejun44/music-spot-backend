# 이 파일을 .env로 복사한 뒤 값을 채워 넣으세요.
# cp .env.example .env

# PostgreSQL 접속 문자열
# 로컬: postgresql://<user>:<password>@localhost:5432/music-spot?schema=public
# Render: 대시보드의 PostgreSQL "Internal Database URL"을 그대로 붙여넣기
DATABASE_URL="postgresql://user:password@localhost:5432/music-spot?schema=public"

# JWT 서명 키 (배포 시 반드시 긴 랜덤 문자열로 교체)
JWT_SECRET="music-spot-secret-key-change-me"

# 서버 포트 (Render는 이 값을 자동 주입한다)
PORT=3000

# 실행 환경: development | production
NODE_ENV=development

# CORS 허용 오리진 (쉼표로 구분)
# 배포 시 Vercel 랜딩 페이지 주소를 넣는다.
CORS_ORIGIN="http://localhost:5500,http://127.0.0.1:5500"
