// Music Spot 백엔드 Prisma 스키마
// 참고: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 서비스 이용자
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  username  String
  createdAt DateTime @default(now())
  posts     Post[]
  rooms     Room[]
}

// 연습실 (크롤링 시드 576곳 + 사용자가 직접 등록한 곳)
model Room {
  id           Int      @id @default(autoincrement())
  name         String
  address      String
  sido         String // 예: "서울" — 지역 드롭다운 1단계
  gungu        String // 예: "마포구" — 지역 드롭다운 2단계
  category     String // "합주실" | "음악연습실"
  pricePerHour Int? // 시간당 요금(원). 패키지 요금만 있는 곳은 null
  imageUrl     String? // 크롤링한 곳의 대표 이미지 주소
  // 사용자가 올린 사진(최대 5장). 파일 저장소가 없어 data URL로 담는다.
  // 브라우저에서 800px·JPEG로 줄여 보내므로 한 장에 100KB 남짓이다.
  images       String[]
  homepageUrl  String? // 홈페이지 또는 예약 링크
  phone        String?
  rating       Float?
  reviewCount  Int?
  hours        String? // 예: "0~24시"
  // 크롤링한 곳의 원본 상세 페이지. 재시드 시 중복을 막는 기준 키.
  // 사용자가 직접 등록한 곳은 원본이 없으므로 null이다.
  sourceUrl    String?  @unique
  // 등록자. 크롤링 시드는 주인이 없어(null) 아무도 지울 수 없다.
  ownerId      Int?
  owner        User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  // 지역 필터가 항상 함께 걸리므로 복합 인덱스로 묶는다.
  @@index([sido, gungu])
  @@index([ownerId])
}

// 커뮤니티 게시글
model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  // 목록은 항상 최신순이라 정렬 컬럼에 인덱스를 둔다.
  @@index([createdAt])
}
